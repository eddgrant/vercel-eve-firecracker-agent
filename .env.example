# Copy to `.env` and fill in. `.env` is gitignored; this template is tracked.
# Eve (Nitro) loads .env automatically in `pnpm dev` / `pnpm start`.

# ============================================================================
# LLM PROVIDER
# ----------------------------------------------------------------------------
# DEFAULT (no config): local Ollama — free, fully local, but small models on a
# 4GB GPU are unreliable tool-users, so the agent is flaky.
#
# HOSTED: set ALL THREE of LLM_BASE_URL, LLM_API_KEY, LLM_MODEL to use any
# OpenAI-compatible provider for fast, reliable tool-calling. Pick whichever
# free tier you can sign up for and uncomment its block.
#
# Free tiers rate-limit (HTTP 429). The agent waits out 429s automatically
# (honouring Retry-After) and can pace requests; tune with:
#   LLM_MAX_RETRIES=6     # times to wait-and-retry a 429 (default 6)
#   LLM_MAX_BACKOFF_MS=60000  # cap a single 429 backoff (default 60s). A
#                         # provider Retry-After LONGER than this is treated as a
#                         # quota window: the turn fails fast with a clear 429
#                         # error instead of silently sleeping it out (which can
#                         # be ~1h on Groq's free tier and looks like a hang).
#   LLM_RPM=15            # optional client-side cap on requests/min
# ============================================================================

# ---- Groq (free; very fast) — https://console.groq.com -----------------------
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile

# ---- Google AI Studio / Gemini (free; easiest signup) ------------------------
#   key: https://aistudio.google.com/apikey
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=...
# LLM_MODEL=gemini-2.0-flash

# ---- OpenRouter (free models) — https://openrouter.ai/keys -------------------
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-...
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# ---- Cerebras (free tier; very fast) — https://cloud.cerebras.ai -------------
# LLM_BASE_URL=https://api.cerebras.ai/v1
# LLM_API_KEY=csk-...
# LLM_MODEL=llama-3.3-70b

# ---- Local Ollama (the default when LLM_* above is unset) --------------------
# Selected by default: the tuned `data-analyst` model (qwen2.5:7b-instruct +
# temperature 0 + num_ctx 16384). It takes the local data-analysis eval from
# ~3/10 to ~8/10 on a 4GB GPU. Build it once with:
#   pnpm ollama:up && pnpm ollama:pull && pnpm ollama:model
OLLAMA_MODEL=data-analyst
# Plain alternatives: qwen2.5:7b-instruct (untuned), qwen2.5:3b-instruct (smaller).
# Do NOT use qwen2.5-coder:7b — it emits tool calls as ```json text, not real calls.
# OLLAMA_BASE_URL=http://localhost:11435/v1
# OLLAMA_API_KEY=ollama

# ---- Debugging --------------------------------------------------------------
# Verbose Eve logging: debug | info | warn | error. `debug` shows the turn loop,
# model calls, and sandbox ops. The `eve dev` TUI only surfaces tool calls/errors
# inline — to see the FULL trace, run a turn through the eval harness:
#   EVE_LOG_LEVEL=debug pnpm eval data-analysis 2>&1 | tee eve-debug.log
# EVE_LOG_LEVEL=debug
#
# OpenTelemetry traces -> Jaeger (model/tool spans, durations, token usage).
# Start the collector with `docker compose up -d jaeger` (UI http://localhost:16686),
# then set this to enable span export (agent/instrumentation.ts is otherwise a
# no-op exporter). NB: spans flush on span END, so a hung turn won't appear —
# use EVE_LOG_LEVEL=debug for hangs, Jaeger for normal-run timing.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ---- ForgeVM (defaults are fine; see scripts/forgevm-serve.sh) --------------
# FORGEVM_BASE_URL=http://127.0.0.1:7423
# FORGEVM_IMAGE=forgevm-pandas:latest
# FORGEVM_PROVIDER=firecracker
